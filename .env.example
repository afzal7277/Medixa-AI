# ─────────────────────────────────────────────────────────────────────────────
# Medixa AI — Environment Variables
# Copy this file to .env and fill in the values before running docker compose.
#
#   cp .env.example .env
#
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── OpenAI ────────────────────────────────────────────────────────────────────
# Required. Get yours at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-your-key-here
OPENAI_MODEL=gpt-4o

# ── Kafka ─────────────────────────────────────────────────────────────────────
# Internal broker address used by services inside docker compose network.
# Change only if running Kafka outside of docker compose.
KAFKA_BOOTSTRAP_SERVERS=kafka:29092

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379

# ── Service URLs (internal docker compose hostnames) ─────────────────────────
ML_SERVICE_URL=http://ml-service:8001
GENAI_SERVICE_URL=http://genai-service:8002

# ── ML model paths (inside containers) ───────────────────────────────────────
MODEL_PATH=/app/model/severity_classifier.onnx
LABEL_ENCODER_PATH=/app/model/label_encoder.json

# ── ML Trainer ────────────────────────────────────────────────────────────────
# Minimum FAERS records required before the first training run.
MIN_SAMPLES=500

# ── Data Pipeline ─────────────────────────────────────────────────────────────
# How often the OpenFDA producer polls for new data (seconds).
POLL_INTERVAL=60

# Retry settings for external API calls.
MAX_RETRIES=3
RETRY_DELAY=5

# ── External API base URLs ────────────────────────────────────────────────────
OPENFDA_BASE_URL=https://api.fda.gov/drug
PUBMED_BASE_URL=https://eutils.ncbi.nlm.nih.gov/entrez/eutils
RXNORM_BASE_URL=https://rxnav.nlm.nih.gov/REST

# ── GenAI Service / ChromaDB ──────────────────────────────────────────────────
# Persistent path for ChromaDB vector store (inside the genai-service container).
CHROMA_PATH=/app/chromadb

# Number of RAG passages retrieved per query.
TOP_K=3

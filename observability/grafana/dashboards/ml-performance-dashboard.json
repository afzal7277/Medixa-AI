{
  "id": null,
  "uid": "medixa-ml-performance",
  "title": "Medixa AI — ML Model Performance",
  "tags": ["ml", "performance", "models"],
  "timezone": "browser",
  "schemaVersion": 36,
  "version": 3,
  "refresh": "15s",
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Inference Latency Percentiles — p50 / p90 / p99 (ms)",
      "description": "ml_inference_latency_ms — XGBoost predict_proba call only, not full HTTP round-trip.",
      "gridPos": {"x": 0, "y": 0, "w": 24, "h": 9},
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": {"lineWidth": 2, "fillOpacity": 8}
        },
        "overrides": [
          {"matcher": {"id": "byName", "options": "p50"}, "properties": [{"id": "color", "value": {"fixedColor": "#73BF69", "mode": "fixed"}}]},
          {"matcher": {"id": "byName", "options": "p90"}, "properties": [{"id": "color", "value": {"fixedColor": "#FADE2A", "mode": "fixed"}}]},
          {"matcher": {"id": "byName", "options": "p99"}, "properties": [{"id": "color", "value": {"fixedColor": "#F2495C", "mode": "fixed"}}]}
        ]
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le) (rate(ml_inference_latency_ms_bucket[5m])))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.90, sum by (le) (rate(ml_inference_latency_ms_bucket[5m])))",
          "legendFormat": "p90"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(ml_inference_latency_ms_bucket[5m])))",
          "legendFormat": "p99"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Inference Latency Histogram — bucket rates",
      "description": "Rate of requests falling into each latency bucket (ms). Shows where most requests land.",
      "gridPos": {"x": 0, "y": 9, "w": 12, "h": 8},
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {"lineWidth": 1, "fillOpacity": 20}
        }
      },
      "targets": [
        {
          "expr": "sum by (le) (rate(ml_inference_latency_ms_bucket[5m]))",
          "legendFormat": "≤{{le}}ms"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Confidence Score Distribution — p50 / p90 / p99",
      "description": "ml_model_confidence histogram. High p50 = well-calibrated model.",
      "gridPos": {"x": 12, "y": 9, "w": 12, "h": 8},
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "custom": {"lineWidth": 2, "fillOpacity": 8}
        }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le) (rate(ml_model_confidence_bucket[5m])))",
          "legendFormat": "p50 confidence"
        },
        {
          "expr": "histogram_quantile(0.90, sum by (le) (rate(ml_model_confidence_bucket[5m])))",
          "legendFormat": "p90 confidence"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(ml_model_confidence_bucket[5m])))",
          "legendFormat": "p99 confidence"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Severity Class Distribution Over Time",
      "description": "ml_severity_predictions_total — rate of each class predicted per second. Stacked to show class mix shifts over time (e.g. after model retrain).",
      "gridPos": {"x": 0, "y": 17, "w": 24, "h": 9},
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 15,
            "stacking": {"mode": "normal", "group": "A"}
          }
        },
        "overrides": [
          {"matcher": {"id": "byName", "options": "Contraindicated"}, "properties": [{"id": "color", "value": {"fixedColor": "#F2495C", "mode": "fixed"}}]},
          {"matcher": {"id": "byName", "options": "Severe"},           "properties": [{"id": "color", "value": {"fixedColor": "#FF9830", "mode": "fixed"}}]},
          {"matcher": {"id": "byName", "options": "Moderate"},         "properties": [{"id": "color", "value": {"fixedColor": "#FADE2A", "mode": "fixed"}}]},
          {"matcher": {"id": "byName", "options": "Mild"},             "properties": [{"id": "color", "value": {"fixedColor": "#73BF69", "mode": "fixed"}}]},
          {"matcher": {"id": "byName", "options": "None"},             "properties": [{"id": "color", "value": {"fixedColor": "#8AB8FF", "mode": "fixed"}}]}
        ]
      },
      "targets": [
        {"expr": "sum(rate(ml_severity_predictions_total{severity='Contraindicated'}[5m]))", "legendFormat": "Contraindicated"},
        {"expr": "sum(rate(ml_severity_predictions_total{severity='Severe'}[5m]))",           "legendFormat": "Severe"},
        {"expr": "sum(rate(ml_severity_predictions_total{severity='Moderate'}[5m]))",         "legendFormat": "Moderate"},
        {"expr": "sum(rate(ml_severity_predictions_total{severity='Mild'}[5m]))",             "legendFormat": "Mild"},
        {"expr": "sum(rate(ml_severity_predictions_total{severity='None'}[5m]))",             "legendFormat": "None"}
      ]
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Total Predictions (24h)",
      "gridPos": {"x": 0, "y": 26, "w": 6, "h": 5},
      "fieldConfig": {"defaults": {"unit": "short"}},
      "targets": [{"expr": "increase(ml_severity_predictions_total[24h])", "legendFormat": "predictions"}],
      "options": {"reduceOptions": {"calcs": ["sum"]}, "colorMode": "value"}
    },
    {
      "id": 6,
      "type": "stat",
      "title": "Median Confidence Score",
      "gridPos": {"x": 6, "y": 26, "w": 6, "h": 5},
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {"mode": "absolute", "steps": [{"color": "red", "value": 0}, {"color": "yellow", "value": 0.6}, {"color": "green", "value": 0.8}]}
        }
      },
      "targets": [{"expr": "histogram_quantile(0.50, sum by (le) (rate(ml_model_confidence_bucket[1h])))", "legendFormat": "p50"}],
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background"}
    },
    {
      "id": 7,
      "type": "stat",
      "title": "Model Retrains (24h)",
      "gridPos": {"x": 12, "y": 26, "w": 6, "h": 5},
      "fieldConfig": {"defaults": {"unit": "short"}},
      "targets": [{"expr": "increase(ml_model_retrain_total[24h])", "legendFormat": "retrains"}],
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "value"}
    },
    {
      "id": 8,
      "type": "stat",
      "title": "Avg Inference Latency p99 (ms)",
      "gridPos": {"x": 18, "y": 26, "w": 6, "h": 5},
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": 0}, {"color": "yellow", "value": 200}, {"color": "red", "value": 500}]}
        }
      },
      "targets": [{"expr": "histogram_quantile(0.99, sum by (le) (rate(ml_inference_latency_ms_bucket[5m])))", "legendFormat": "p99"}],
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background"}
    }
  ],
  "templating": {"list": []},
  "annotations": {"list": []}
}

{
  "id": null,
  "uid": "medixa-ml-performance",
  "title": "Medixa AI ML Performance",
  "tags": ["ml", "performance", "models"],
  "timezone": "browser",
  "schemaVersion": 36,
  "version": 1,
  "refresh": "15s",
  "panels": [
    {
      "type": "timeseries",
      "title": "ML Inference Latency (P95)",
      "gridPos": {"x": 0, "y": 0, "w": 12, "h": 8},
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, model) (rate(ml_inference_latency_ms_bucket[5m])))",
          "legendFormat": "{{model}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "ML Confidence Score Distribution",
      "gridPos": {"x": 12, "y": 0, "w": 12, "h": 8},
      "targets": [
        {
          "expr": "histogram_quantile(0.5, sum by (le, model) (rate(ml_model_confidence_bucket[5m])))",
          "legendFormat": "{{model}} P50"
        },
        {
          "expr": "histogram_quantile(0.9, sum by (le, model) (rate(ml_model_confidence_bucket[5m])))",
          "legendFormat": "{{model}} P90"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Severity Classification Distribution",
      "gridPos": {"x": 0, "y": 8, "w": 24, "h": 8},
      "targets": [
        {
          "expr": "sum(rate(severity_class_distribution[5m])) by (severity)",
          "legendFormat": "{{severity}}"
        }
      ]
    }
  ],
  "templating": {"list": []},
  "annotations": {"list": []}
}

      "gridPos": {"x": 16, "y": 25, "w": 8, "h": 5},
      "fieldConfig": {
        "defaults": {
          "mappings": [{"type": "value", "options": {"0": {"text": "DOWN", "color": "red"}, "1": {"text": "UP", "color": "green"}}}],
          "thresholds": {"mode": "absolute", "steps": [{"color": "red", "value": 0}, {"color": "green", "value": 1}]}
        }
      },
      "targets": [{"expr": "up{job='genai-service'}", "legendFormat": "genai-service"}],
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background"}
    },
    {
      "id": 9,
      "type": "stat",
      "title": "Uptime — prometheus",
      "gridPos": {"x": 0, "y": 30, "w": 12, "h": 5},
      "fieldConfig": {
        "defaults": {
          "mappings": [{"type": "value", "options": {"0": {"text": "DOWN", "color": "red"}, "1": {"text": "UP", "color": "green"}}}],
          "thresholds": {"mode": "absolute", "steps": [{"color": "red", "value": 0}, {"color": "green", "value": 1}]}
        }
      },
      "targets": [{"expr": "up{job='prometheus'}", "legendFormat": "prometheus"}],
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background"}
    },
    {
      "id": 10,
      "type": "stat",
      "title": "Uptime — grafana",
      "gridPos": {"x": 12, "y": 30, "w": 12, "h": 5},
      "fieldConfig": {
        "defaults": {
          "mappings": [{"type": "value", "options": {"0": {"text": "DOWN", "color": "red"}, "1": {"text": "UP", "color": "green"}}}],
          "thresholds": {"mode": "absolute", "steps": [{"color": "red", "value": 0}, {"color": "green", "value": 1}]}
        }
      },
      "targets": [{"expr": "up{job='grafana'}", "legendFormat": "grafana"}],
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background"}
    }
  ],

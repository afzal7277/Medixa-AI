{
  "id": null,
  "uid": "medixa-system-health",
  "title": "Medixa AI System Health",
  "tags": ["observability", "system", "health"],
  "timezone": "browser",
  "schemaVersion": 36,
  "version": 1,
  "refresh": "15s",
  "panels": [
    {
      "type": "timeseries",
      "title": "API Request Latency (P95)",
      "gridPos": {"x": 0, "y": 0, "w": 12, "h": 8},
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, method, path) (rate(fastapi_http_request_duration_seconds_bucket{job='api-gateway'}[5m])))",
          "legendFormat": "{{method}} {{path}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "API 5xx Error Rate",
      "gridPos": {"x": 12, "y": 0, "w": 12, "h": 8},
      "targets": [
        {
          "expr": "sum(rate(fastapi_http_requests_total{job='api-gateway', status_code=~'5..'} [5m])) by (method, path)",
          "legendFormat": "{{method}} {{path}}"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Service Availability (up)",
      "gridPos": {"x": 0, "y": 8, "w": 24, "h": 6},
      "targets": [
        {
          "expr": "up{job=~\"api-gateway|ml-service|genai-service|prometheus|grafana|data-pipeline-producer|data-pipeline-consumer\"}",
          "legendFormat": "{{job}}"
        }
      ]
    }
  ],
  "templating": {"list": []},
  "annotations": {"list": []}
}

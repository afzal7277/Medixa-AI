FROM python:3.11-slim

# System deps for playwright + numpy
RUN apt-get update && apt-get install -y --no-install-recommends \
    gcc g++ curl \
    # Playwright system deps
    libnss3 libatk1.0-0 libatk-bridge2.0-0 libcups2 libdrm2 \
    libxkbcommon0 libxcomposite1 libxdamage1 libxfixes3 libxrandr2 \
    libgbm1 libasound2 libpango-1.0-0 libcairo2 libx11-6 \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Copy service source (tests import these modules directly)
COPY api-gateway/   api-gateway/
COPY ml-service/    ml-service/
COPY genai-service/ genai-service/
COPY data-pipeline/ data-pipeline/

# Copy tests
COPY tests/ tests/

# Install test dependencies
RUN pip install --no-cache-dir -r tests/requirements-test.txt

# Install Playwright browsers (only chromium needed for E2E)
RUN playwright install chromium --with-deps 2>/dev/null || true

# Results directory (will be mounted as a volume)
RUN mkdir -p tests/results

# Default: unit + integration (no Docker/Kafka)
CMD ["pytest", "tests/unit/", "tests/integration/", \
     "-v", "--tb=short", \
     "-c", "tests/pytest.ini", \
     "--html=tests/results/report.html", "--self-contained-html", \
     "--cov=api-gateway", "--cov=ml-service", \
     "--cov=genai-service", "--cov=data-pipeline", \
     "--cov-report=html:tests/results/coverage", \
     "--cov-report=term-missing:skip-covered"]

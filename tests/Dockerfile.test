FROM python:3.11-slim

# System deps for numpy + Playwright
RUN apt-get update && apt-get install -y --no-install-recommends \
    gcc g++ curl \
    libnss3 libatk1.0-0 libatk-bridge2.0-0 libcups2 libdrm2 \
    libxkbcommon0 libxcomposite1 libxdamage1 libxfixes3 libxrandr2 \
    libgbm1 libasound2 libpango-1.0-0 libcairo2 libx11-6 \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# ── Install dependencies FIRST (cached layer — only reruns when requirements-test.txt changes) ──
COPY tests/requirements-test.txt tests/requirements-test.txt
RUN pip install --no-cache-dir -r tests/requirements-test.txt

# Install Playwright browser (also cached — only reruns if playwright version changes)
RUN playwright install chromium --with-deps 2>/dev/null || true

# ── Copy source AFTER pip install (code changes don't invalidate the pip cache layer) ──
COPY api-gateway/   api-gateway/
COPY ml-service/    ml-service/
COPY genai-service/ genai-service/
COPY data-pipeline/ data-pipeline/
COPY tests/ tests/

# Results directory (mounted as a volume by docker-compose.test.yml)
RUN mkdir -p tests/results

# Default: unit + integration (no Docker/Kafka socket needed)
CMD ["pytest", "tests/unit/", "tests/integration/", \
     "-v", "--tb=short", \
     "-c", "tests/pytest.ini", \
     "--html=tests/results/report.html", "--self-contained-html", \
     "--cov=api-gateway", "--cov=ml-service", \
     "--cov=genai-service", "--cov=data-pipeline", \
     "--cov-report=html:tests/results/coverage", \
     "--cov-report=term-missing:skip-covered"]
